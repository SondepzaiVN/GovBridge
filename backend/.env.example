NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_MB=8
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Provider boundaries. mock mode requires no external credentials.
# ASSISTANT_PROVIDER is kept only as a legacy selector.
ASSISTANT_PROVIDER=mock
ORCHESTRATOR_PROVIDER=mock
KNOWLEDGE_PROVIDER=mock
OCR_PROVIDER=mock
TTS_PROVIDER=mock

# VNPT eKYC (required only when OCR_PROVIDER=vnpt)
VNPT_EKYC_URL=https://api.idg.vnpt.vn
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
VNPT_MAC_ADDRESS=GOV_BRIDGE_BACKEND

# VNPT TTS (required only when TTS_PROVIDER=vnpt)
VNPT_TTS_URL=https://api.idg.vnpt.vn/tts-service/v2/grpc
VNPT_TTS_ACCESS_TOKEN=
VNPT_TTS_TOKEN_ID=
VNPT_TTS_TOKEN_KEY=

# VNPT STT (Speech to Text)
VNPT_STT_URL=wss://stt.vnpt.vn/ws/asr
VNPT_STT_ACCESS_TOKEN=
VNPT_STT_TOKEN_ID=
VNPT_STT_TOKEN_KEY=

# VNPT Agentic KnowledgeProvider (required only when KNOWLEDGE_PROVIDER=vnpt)
VNPT_AGENTIC_URL=https://assistant-stream.vnpt.vn/v1/conversation
VNPT_AGENTIC_ACCESS_TOKEN=
VNPT_AGENTIC_TOKEN_ID=
VNPT_AGENTIC_TOKEN_KEY=
VNPT_AGENTIC_BOT_ID=
VNPT_AGENTIC_TIMEOUT_MS=30000

# OpenAI Responses API Orchestrator (required only when ORCHESTRATOR_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT_MS=30000
