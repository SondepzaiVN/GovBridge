# GovBridge backend environment
# Keep secrets only in .env. Use .env.example as the shared template.

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_MB=8
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Provider selection
ASSISTANT_PROVIDER=vnpt
ORCHESTRATOR_PROVIDER=openai
KNOWLEDGE_PROVIDER=vnpt
OCR_PROVIDER=mock
STT_PROVIDER=mock
TTS_PROVIDER=mock

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT_MS=30000

# VNPT SmartBot / Assistant Livechat
VNPT_AGENTIC_URL=https://assistant-stream.vnpt.vn/v1/conversation
VNPT_ASSISTANT_TOKEN=
VNPT_ASSISTANT_BOT_ID=e0ae8190-769a-11f1-a4d2-f99c9477e903
VNPT_ASSISTANT_SENDER_ID=team.25@vnptai.io
VNPT_ASSISTANT_REFERER=https://livechat.vnpt.vn/
VNPT_AGENTIC_TIMEOUT_MS=30000

# VNPT SmartBot legacy compatibility
VNPT_AGENTIC_ACCESS_TOKEN=
VNPT_AGENTIC_TOKEN_ID=
VNPT_AGENTIC_TOKEN_KEY=
VNPT_AGENTIC_BOT_ID=
VNPT_SMARTBOT_URL=https://assistant-stream.vnpt.vn/v1/conversation
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_BOT_ID=

# VNPT eKYC / CCCD OCR
VNPT_EKYC_URL=https://api.idg.vnpt.vn
VNPT_EKYC_AUTH_URL=https://api.idg.vnpt.vn/auth/oauth/token
VNPT_EKYC_CLIENT_ID=
VNPT_EKYC_CLIENT_SECRET=
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_CLIENT_ID=
VNPT_EKYC_CLIENT_SECRET=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
VNPT_MAC_ADDRESS=GOV_BRIDGE_BACKEND

# VNPT SmartReader / Document OCR
VNPT_SMARTREADER_URL=https://api.idg.vnpt.vn
VNPT_SMARTREADER_ACCESS_TOKEN=
VNPT_SMARTREADER_TOKEN_ID=
VNPT_SMARTREADER_TOKEN_KEY=
VNPT_SMARTREADER_TIMEOUT_MS=45000

# VNPT SmartVoice STT
VNPT_STT_URL=wss://stt.vnpt.vn/ws/asr
VNPT_STT_ACCESS_TOKEN=
VNPT_STT_TOKEN_ID=
VNPT_STT_TOKEN_KEY=
VNPT_STT_TIMEOUT_MS=30000

# VNPT SmartVoice TTS
VNPT_TTS_URL=https://api.idg.vnpt.vn/tts-service/v2/grpc
VNPT_TTS_ACCESS_TOKEN=
VNPT_TTS_TOKEN_ID=
VNPT_TTS_TOKEN_KEY=

# Document review
DOCUMENT_RULES_PATH=rules.md
