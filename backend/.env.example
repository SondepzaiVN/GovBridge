NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_MB=8
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# mock: backend works without external credentials
ASSISTANT_PROVIDER=mock
OCR_PROVIDER=mock
TTS_PROVIDER=mock

# VNPT eKYC (required only when OCR_PROVIDER=vnpt)
VNPT_EKYC_URL=https://api.idg.vnpt.vn
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
VNPT_MAC_ADDRESS=GOV_BRIDGE_BACKEND

# VNPT TTS (required only when TTS_PROVIDER=vnpt)
VNPT_TTS_URL=https://api.idg.vnpt.vn/tts-service/v2/grpc
VNPT_VOICE_ACCESS_TOKEN=
VNPT_VOICE_TOKEN_ID=
VNPT_VOICE_TOKEN_KEY=
