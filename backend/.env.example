NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_MB=8
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# mock: backend works without external credentials
ASSISTANT_PROVIDER=mock
OCR_PROVIDER=mock
TTS_PROVIDER=mock

# VNPT eKYC (required only when OCR_PROVIDER=vnpt)
VNPT_EKYC_URL=https://api.idg.vnpt.vn
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
VNPT_MAC_ADDRESS=GOV_BRIDGE_BACKEND

# VNPT TTS (required only when TTS_PROVIDER=vnpt)
VNPT_TTS_URL=https://api.idg.vnpt.vn/tts-service/v2/grpc
VNPT_TTS_ACCESS_TOKEN=
VNPT_TTS_TOKEN_ID=
VNPT_TTS_TOKEN_KEY=

# VNPT STT (Speech to Text)
VNPT_STT_URL=wss://stt.vnpt.vn/ws/asr
VNPT_STT_ACCESS_TOKEN=
VNPT_STT_TOKEN_ID=
VNPT_STT_TOKEN_KEY=

# VNPT Smartbot (required only when ASSISTANT_PROVIDER=vnpt)
VNPT_SMARTBOT_URL=https://smartbot.vnpt.vn/api/v1
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_BOT_ID=
